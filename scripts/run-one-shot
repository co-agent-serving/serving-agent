#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"
cd "$SCRIPT_DIR/.."

PROMPT="${1:-Huawei is}"

if [ ! -d "$MODEL_DIR" ]; then
    echo "Error: MODEL_DIR=$MODEL_DIR not found. Set MODEL_DIR in scripts/env." >&2
    exit 1
fi

task-submit --device auto --run \
  "cd $(pwd) && cargo run --bin rust_llm_server -- \
     --weights '$MODEL_DIR' \
     --prompt '$PROMPT'"
