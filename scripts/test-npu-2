#!/usr/bin/env bash
# Run HCCL multi-rank smoke test on 2 NPUs via task-submit.
# Always runs via task-submit (auto-allocates 2 devices).
# The actual multi-rank launch is delegated to scripts/lib/test-npu-2-run.
set -euo pipefail

cd "$(dirname "$0")/.."

task-submit --device auto --device-num 2 --run \
  "cd $(pwd) && bash scripts/lib/test-npu-2-run"
