#!/usr/bin/env bash
# Run all lints for the serving agent.
# CI matrix: default (CANN always linked) vs --features simpler (PyPTO kernel dispatch).
set -euo pipefail

cd "$(dirname "$0")/.."

check_setup() {
    local label="$1"
    shift

    echo "--- check $label ---"
    cargo check --lib --bins --tests "$@"

    echo "--- clippy $label ---"
    cargo clippy --lib --bins --tests "$@" -- -D warnings

    echo "--- doc $label ---"
    cargo doc --no-deps "$@"

    echo "--- test-compile $label ---"
    cargo test --no-run "$@"
}

# Fastest check first — catches formatting issues before any compilation
echo "--- fmt ---"
cargo fmt --all --check

check_setup "default (CANN always linked)" --workspace

echo "All checks passed."
