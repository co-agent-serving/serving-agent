#!/usr/bin/env bash
# Run all lints for the serving agent.
# Feature-gate strategy: default (stub, no NPU) vs --features ascend (incl. PyPTO binding).
set -euo pipefail

cd "$(dirname "$0")/.."

check_setup() {
    local label="$1"
    shift

    echo "--- check $label ---"
    cargo check --lib --bins --tests "$@"

    echo "--- clippy $label ---"
    cargo clippy --lib --bins --tests "$@" -- -D warnings

    echo "--- doc $label ---"
    cargo doc --no-deps "$@"

    echo "--- test-compile $label ---"
    cargo test --no-run "$@"
}

# Fastest check first — catches formatting issues before any compilation
echo "--- fmt ---"
cargo fmt --all --check

check_setup "default (stub)" --workspace
check_setup "ascend + hccl" -p rust_llm_server --features "ascend,hccl"
check_setup "ascend crate stub" -p ascend --features stub

echo "All checks passed."
